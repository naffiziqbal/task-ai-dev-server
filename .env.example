# Postgres
POSTGRES_USER=psl
POSTGRES_PASSWORD=psl
POSTGRES_DB=psl
POSTGRES_PORT=5432
DATABASE_URL=postgres://psl:psl@localhost:5432/psl

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# DigitalOcean Spaces (S3-compatible blob storage).
# Get credentials at https://cloud.digitalocean.com/account/api/spaces
DO_SPACES_ACCESS_KEY_ID=
DO_SPACES_SECRET_ACCESS_KEY=
DO_SPACES_REGION=
DO_SPACES_BUCKET=
DO_SPACES_ENDPOINT=
# Optional — if the Space has the CDN enabled, presignGet() will return
# direct CDN URLs (faster, no signing). Format: https://<bucket>.<region>.cdn.digitaloceanspaces.com
# DO_SPACES_CDN_BASE=

# API
API_PORT=4000
# Origin of the client app — used for CORS.
WEB_ORIGIN=http://localhost:3000

# OpenAI (single key powers both generation and embeddings).
# Create one at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Main generation model used for extraction and drafting.
# Alternatives: gpt-5.5 (newest), gpt-5.4-mini (cheaper), gpt-4.1 (older).
OPENAI_MODEL=gpt-5.4
# Cheaper/faster model for high-volume calls (edit classification).
OPENAI_FAST_MODEL=gpt-5.4-mini
# Embedding model. text-embedding-3-small returns 1536-dim by default; we
# pass `dimensions=EMBEDDING_DIM` in code so it matches the pgvector schema
# (768 here — matryoshka truncation, minimal quality loss).
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=768
